# =============================================
# 云深飞运 环境变量
# 复制为 .env 并填入实际值
# =============================================

# 火山引擎Supabase
SUPABASE_URL=https://xxx.volcengineapi.com
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# 微信（客户端小程序）
WX_CLIENT_APPID=wx_xxx
WX_CLIENT_SECRET=xxx

# 微信（飞手端小程序）
WX_PILOT_APPID=wx_xxx
WX_PILOT_SECRET=xxx

# 微信支付V3
WX_PAY_MCHID=xxx
WX_PAY_V3_SECRET=xxx
WX_PAY_CERT_PATH=./certs/apiclient_key.pem

# 高德地图
AMAP_KEY=xxx

# 腾讯位置服务
QQMAP_KEY=xxx
